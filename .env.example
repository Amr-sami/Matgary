# Postgres connection (matches docker-compose.yml defaults)
DATABASE_URL=postgres://matgary:matgary@localhost:5434/matgary
# Same database, but a NOSUPERUSER role so RLS policies are enforced.
APP_DATABASE_URL=postgres://matgary_app:matgary_app@localhost:5434/matgary

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET=

# Symmetric key for encrypting per-tenant Green API tokens at rest
# 32 random bytes, base64 — generate with: openssl rand -base64 32
SECRET_KEY=

# Redis (optional) — opportunistic cache + rate limiter (lib/redis.ts).
# When unset or unreachable the app falls back to Postgres directly, so this
# is safe to leave blank in dev environments without docker. The compose file
# maps the container to host port 6381 to dodge other locally running Redis
# instances.
REDIS_URL=redis://localhost:6381

# Set to "1" to bypass Redis even when REDIS_URL is configured. Useful as a
# fast rollback switch without redeploying.
# CACHE_DISABLED=1

# Set to "1" to log every cache hit/miss (noisy — debug only).
# CACHE_DEBUG=1

# Outbound email — used by the forgot-password flow and any future
# transactional email. When SMTP_HOST is unset, mailer logs to the server
# console instead so dev flows are testable without an SMTP server.
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=587
# SMTP_USER=resend
# SMTP_PASS=
# SMTP_SECURE=0
# MAIL_FROM=Matgary <no-reply@your-domain>

# Sentry (optional) — only initialised when SENTRY_DSN is present.
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=production

# Shared bearer token for the periodic cron sweeps (POST /api/cron/*).
# Generate a long random string: openssl rand -base64 48
# Without this set, every cron route returns 401. The docker-compose `cron`
# sidecar reads the same value and sends it as `Authorization: Bearer …`.
CRON_SECRET=

# Internal URL the cron sidecar uses to reach the app. In compose this is
# `http://app:3000` (the next service); in standalone deployments point it
# at whatever the runner can reach (loopback, internal LB, etc.).
CRON_TARGET_URL=http://app:3000

# Days to keep activity_logs rows before the daily cleanup deletes them.
# Default 730 = 2 years. Clamped 30..3650 by the route handler.
# ACTIVITY_LOG_RETENTION_DAYS=730
